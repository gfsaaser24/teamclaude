{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/renderer/src/assets/main.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@renderer/components",
    "utils": "@renderer/lib/utils",
    "ui": "@renderer/components/ui",
    "lib": "@renderer/lib",
    "hooks": "@renderer/hooks"
  },
  "registries": {
    "@ss-components": {
      "url": "https://shadcnstudio.com/r/components/{style}/{name}.json",
      "params": { "email": "${EMAIL}", "license_key": "${LICENSE_KEY}" }
    },
    "@ss-themes": {
      "url": "https://shadcnstudio.com/r/themes/{name}.json",
      "params": { "email": "${EMAIL}", "license_key": "${LICENSE_KEY}" }
    },
    "@ss-blocks": {
      "url": "https://shadcnstudio.com/r/blocks/{style}/{name}.json",
      "params": { "email": "${EMAIL}", "license_key": "${LICENSE_KEY}" }
    }
  }
}
